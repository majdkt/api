# Teze API – local development environment
# Copy this to .env and adjust for your setup.
# DO NOT commit .env to version control.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of browser origins allowed to reach this API.
# Add your server IP / Tailscale hostname as needed.
# Dev defaults (localhost:4321 Astro dev, localhost:4322 Astro preview) are
# always included automatically; only add extra origins here.
FRONTEND_ORIGIN=http://localhost:4321
# FRONTEND_ORIGIN=http://192.168.1.100:4321

# ── Docker ────────────────────────────────────────────────────────────────────
# Path to the Docker Engine Unix socket.
DOCKER_SOCKET=/var/run/docker.sock

# ── Network Diagnostics ───────────────────────────────────────────────────────
# Host used for gateway latency measurement (ping target).
PING_HOST=1.1.1.1
