# Teze API – environment variable reference
# Copy this file to .env and fill in your values.
# DO NOT commit .env to version control.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── CORS ─────────────────────────────────────────────────────────────────────
# Browser origins allowed to reach the API (comma-separated if multiple).
# Dev defaults localhost:4321 and localhost:4322 are always included.
FRONTEND_ORIGIN=http://localhost:4321
# FRONTEND_ORIGIN=http://192.168.1.100:4321

# ── Docker ────────────────────────────────────────────────────────────────────
# Path to the Docker Engine Unix socket.
DOCKER_SOCKET=/var/run/docker.sock

# ── Network Diagnostics ───────────────────────────────────────────────────────
# Host used for gateway latency measurement (ping target).
PING_HOST=1.1.1.1
