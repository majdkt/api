# Teze API – environment variable reference
# Copy to .env and fill in your values. DO NOT commit .env.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── CORS ─────────────────────────────────────────────────────────────────────
# Browser origin(s) allowed to reach this API (comma-separated).
# localhost:4321 and localhost:4322 are always included in dev.
FRONTEND_ORIGIN=http://localhost:4321

# ── Docker ────────────────────────────────────────────────────────────────────
DOCKER_SOCKET=/var/run/docker.sock

# ── Network diagnostics ───────────────────────────────────────────────────────
PING_HOST=1.1.1.1
